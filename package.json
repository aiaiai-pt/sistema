{
  "name": "@aiaiai-pt/design-system",
  "version": "0.43.0",
  "description": "Design system tokens and Svelte components for aiaiai products",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/aiaiai-pt/sistema.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "site"
  ],
  "scripts": {
    "build:types": "rm -f components/*.d.ts components/renderer/*.d.ts && svelte-package --input . --output dist && cp dist/components/*.d.ts components/ && cp dist/components/renderer/*.d.ts components/renderer/ && rm -rf dist",
    "test": "vitest run",
    "prepublishOnly": "npm run build:types"
  },
  "svelte": "./components/index.js",
  "exports": {
    ".": {
      "types": "./components/index.d.ts",
      "svelte": "./components/index.js",
      "default": "./components/index.js"
    },
    "./components": {
      "types": "./components/index.d.ts",
      "svelte": "./components/index.js",
      "default": "./components/index.js"
    },
    "./components/*.svelte": {
      "types": "./components/*.svelte.d.ts",
      "svelte": "./components/*.svelte",
      "default": "./components/*.svelte"
    },
    "./components/*": {
      "types": "./components/*.d.ts",
      "svelte": "./components/*",
      "default": "./components/*"
    },
    "./renderer/*.svelte": {
      "types": "./components/renderer/*.svelte.d.ts",
      "svelte": "./components/renderer/*.svelte",
      "default": "./components/renderer/*.svelte"
    },
    "./renderer/*": {
      "types": "./components/renderer/*.d.ts",
      "svelte": "./components/renderer/*",
      "default": "./components/renderer/*"
    },
    "./tokens/*": "./tokens/*"
  },
  "files": [
    "components",
    "tokens"
  ],
  "peerDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.0.0",
    "date-fns": "^4.1.0",
    "echarts": "^5.5.0",
    "ol": "^10.0.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "date-fns": "^4.1.0",
    "echarts": "^5.6.0",
    "jsdom": "^29.1.1",
    "ol": "^10.8.0",
    "svelte": "^5.55.3",
    "svelte-check": "^4.4.6",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
